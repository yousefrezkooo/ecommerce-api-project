{
  "info": {
    "name": "eCommerce Backend API",
    "description": "Product and cart endpoints for the eCommerce Backend project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "productId", "value": "" },
    { "key": "cartId", "value": "" }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Get all products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Get product by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop\",\n  \"price\": 899.99,\n  \"description\": \"14-inch laptop, 16GB RAM.\",\n  \"category\": \"Electronics\"\n}"
            },
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 849.99\n}"
            },
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Carts",
      "item": [
        {
          "name": "Create cart",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/carts"
          }
        },
        {
          "name": "Get cart by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/carts/{{cartId}}"
          }
        },
        {
          "name": "Add item to cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/api/carts/{{cartId}}/items"
          }
        },
        {
          "name": "Delete cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/carts/{{cartId}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Add review for product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Great product!\",\n  \"shopperName\": \"Sam\"\n}"
            },
            "url": "{{baseUrl}}/api/products/{{productId}}/reviews"
          }
        },
        {
          "name": "Get reviews for product",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}/reviews"
          }
        }
      ]
    }
  ]
}
